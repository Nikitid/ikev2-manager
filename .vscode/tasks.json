{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "check:bash",
      "type": "shell",
      "command": "find . -type f -name '*.sh' -print0 | xargs -0 bash -n && find . -type f -name '*.sh' -print0 | xargs -0 shellcheck",
      "problemMatcher": []
    },
    {
      "label": "format:bash",
      "type": "shell",
      "command": "find . -type f -name '*.sh' -print0 | xargs -0 shfmt -w",
      "problemMatcher": []
    },
    {
      "label": "git:status",
      "type": "shell",
      "command": "git status --short",
      "problemMatcher": []
    }
  ]
}
